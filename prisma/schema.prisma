generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Aura enums ──

enum AuraOutboxStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum AuraJobRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

// ── JC Import Express enums ──

enum TransportMode {
  AVION
  BATEAU
}



enum RequestStatus {
  EN_ATTENTE
  EN_COURS
  EN_PAUSE
  PROBLEME
  TERMINE
  ANNULEE
}

enum RequestProblemType {
  DOUANE
  POLICE
  DOCUMENTATION
  RETARD_LOGISTIQUE
  PAIEMENT
  AUTRE
}

enum TrajectoryStepType {
  ORIGIN
  ESCALE
  DESTINATION
}

enum LegMode {
  TRUCK
  PLANE
  BOAT
}

enum JcNotificationType {
  GENERAL
  REQUEST_CREATED
  REQUEST_STATUS_UPDATED
  TRAJECTORY_UPDATED
  WHATSAPP_DISCUSSION_READY
}

// ── Aura auth core ──

model AuraUser {
  id                  String                   @id @default(cuid())
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  disabledAt          DateTime?
  deletedAt           DateTime?
  sessionVersion      Int                      @default(1)

  // Auth fields
  username            String                   @unique
  email               String?                  @unique
  phone               String?
  displayName         String?
  businessName        String?
  isAdmin             Boolean                  @default(false)
  isBlocked           Boolean                  @default(false)
  countryId           String?
  country             Country?                 @relation("UserCountry", fields: [countryId], references: [id], onDelete: SetNull)
  currencyCode        String?
  onboardingCompleted Boolean                  @default(false)

  passwordCredential  AuraPasswordCredential?
  sessions            AuraSession[]
  notifications       AuraNotification[]
  auditLogs           AuraAuditLog[]

  // JC Import Express relations
  requests            Request[]                @relation("RequestCustomer")
  jcNotifications     JcNotification[]

  @@index([phone])
}

model AuraPasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         AuraUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuraSession {
  id              String    @id @default(cuid())
  tokenHash       String    @unique
  csrfTokenHash   String
  userId          String
  expiresAt       DateTime
  revokedAt       DateTime?
  lastUsedAt      DateTime  @default(now())
  userAgentHash   String?
  ipHash          String?
  sessionVersion  Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            AuraUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuraNotification {
  id              String    @id @default(cuid())
  name            String
  recipientUserId String?
  title           String
  body            String
  payload         Json?
  readAt          DateTime?
  createdAt       DateTime  @default(now())
  recipient       AuraUser? @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, readAt, createdAt])
  @@index([name])
}

model AuraOutboxEvent {
  id          String           @id @default(cuid())
  type        String
  payload     Json
  status      AuraOutboxStatus @default(PENDING)
  attempts    Int              @default(0)
  maxAttempts Int              @default(5)
  nextRunAt   DateTime         @default(now())
  lockedAt    DateTime?
  processedAt DateTime?
  error       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, nextRunAt])
  @@index([type])
}

model AuraJobRun {
  id         String           @id @default(cuid())
  jobName    String
  status     AuraJobRunStatus
  requestId  String?
  attempts   Int              @default(1)
  metadata   Json?
  error      String?
  startedAt  DateTime         @default(now())
  finishedAt DateTime?

  @@index([jobName, startedAt])
  @@index([status])
}

model AuraAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  operation   String?
  requestId   String?
  source      String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       AuraUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([requestId])
}

model AuraFile {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  url       String
  mimeType  String
  size      Int
  prefix    String
  storage   String   @default("filesystem")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prefix])
  @@index([storage])
}

// ── JC Import Express business models ──

model Country {
  id                  String           @id @default(cuid())
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  name                String
  slug                String           @unique
  iso2                String           @unique
  dialingCode         String
  currencyCode        String
  currencyName        String
  currencySymbol      String
  usdExchangeRate     Float            @default(1)
  continent           String           @default("Africa")
  isFeatured          Boolean          @default(false)
  isActive            Boolean          @default(true)
  isHub               Boolean          @default(false)
  auraUsers           AuraUser[]       @relation("UserCountry")
  destinationRequests Request[]        @relation("RequestDestinationCountry")
  originRequests      Request[]        @relation("RequestOriginCountry")
  trajectorySteps     TrajectoryStep[] @relation("TrajectoryStepCountry")
}

model Request {
  id                        String              @id @default(cuid())
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  requestNumber             String              @unique
  type                      String              @default("SHIPMENT")
  userId                    String
  user                      AuraUser            @relation("RequestCustomer", fields: [userId], references: [id], onDelete: Cascade)
  originCountryId           String?
  originCountry             Country?            @relation("RequestOriginCountry", fields: [originCountryId], references: [id], onDelete: SetNull)
  destinationCountryId      String
  destinationCountry        Country             @relation("RequestDestinationCountry", fields: [destinationCountryId], references: [id])
  recipientName             String
  recipientPhone            String
  deliveryAddress           String
  city                      String?
  region                    String?
  packageWeightKg           Float?
  packageCount              Int                 @default(1)
  productDescription        String              @default("")
  transportMode             TransportMode
  customerNotes             String?
  adminNotes                String?
  status                    RequestStatus       @default(EN_ATTENTE)
  problemType               RequestProblemType?
  whatsappDiscussionLink    String?
  latestStatusMessage       String?
  needsRectification        Boolean             @default(false)
  trajectorySteps           TrajectoryStep[]
  statusEvents              RequestStatusEvent[]
  jcNotifications   JcNotification[]
  journey           Journey?

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
}

model TrajectoryStep {
  id          String             @id @default(cuid())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  requestId   String
  request     Request            @relation(fields: [requestId], references: [id], onDelete: Cascade)
  countryId   String?
  country     Country?           @relation("TrajectoryStepCountry", fields: [countryId], references: [id], onDelete: SetNull)
  locationName String
  stepType    TrajectoryStepType
  legMode     LegMode              @default(TRUCK)
  sequence    Int
  reachedAt   DateTime?
  note        String?
  timerDurationHours Int      @default(4)
  timerStartedAt     DateTime?
  timerEndsAt        DateTime?
  isTimerPaused      Boolean   @default(false)
  pausedRemainingMinutes Int?
  // Mapbox geocoding
  latitude    Float?
  longitude   Float?

  @@unique([requestId, sequence])
}

model RequestStatusEvent {
  id             String             @id @default(cuid())
  createdAt      DateTime           @default(now())
  requestId      String
  request        Request            @relation(fields: [requestId], references: [id], onDelete: Cascade)
  status         RequestStatus
  problemType    RequestProblemType?
  title          String
  message        String
  createdByLabel String?

  @@index([requestId, createdAt])
}

model JcNotification {
  id              String                    @id @default(cuid())
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  userId          String
  user            AuraUser                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId       String?
  request         Request?                  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type            JcNotificationType
  title           String
  message         String
  deepLink        String
  whatsappMessage String?
  isRead          Boolean                   @default(false)
  sentAt          DateTime?

  @@index([userId, isRead, createdAt])
}

enum JourneyTransportType {
  MARITIME
  AERIEN
}

enum JourneyStatus {
  BROUILLON
  PLANIFIE
  EN_COURS
  EN_PAUSE
  PROBLEME
  TERMINE
  ANNULE
}

enum JourneyStopType {
  DEPART
  ESCALE
  DESTINATION
}

enum JourneySpeedUnit {
  KNOTS
  KMH
}

enum JourneyEventType {
  CREATED
  PLAN_UPDATED
  PUBLISHED
  STARTED
  STOP_REACHED
  ETA_UPDATED
  PAUSED
  RESUMED
  PROBLEM_REPORTED
  PROBLEM_RESOLVED
  COMPLETED
  NOTE
}

model Journey {
  id                String               @id @default(cuid())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  requestId         String               @unique
  request           Request              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  publicToken       String               @unique
  vehicleName       String
  transportType     JourneyTransportType
  status            JourneyStatus        @default(BROUILLON)
  averageSpeed      Float?
  speedUnit         JourneySpeedUnit?
  publishedAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  latestMessage     String?
  problemMessage    String?
  stops             JourneyStop[]
  events            JourneyEvent[]

  @@index([status, updatedAt])
  @@index([requestId])
}

model JourneyStop {
  id                 String          @id @default(cuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  journeyId          String
  journey            Journey         @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  placeName          String
  placeLabel         String?
  mapboxPlaceId      String?
  latitude           Float
  longitude          Float
  stopType           JourneyStopType
  sequence           Int
  estimatedArrivalAt DateTime?
  reachedAt          DateTime?
  note               String?

  @@unique([journeyId, sequence])
  @@index([journeyId, reachedAt, sequence])
}

model JourneyEvent {
  id                String           @id @default(cuid())
  createdAt         DateTime         @default(now())
  journeyId         String
  journey           Journey          @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  stopId            String?
  eventType         JourneyEventType
  title             String
  message           String
  visibleToCustomer Boolean          @default(true)
  createdByLabel    String?

  @@index([journeyId, createdAt])
  @@index([journeyId, visibleToCustomer, createdAt])
}


model AppSettings {
  id                  String   @id @default("default")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  adminWhatsAppNumber String?
  evolutionInstanceId String?
}

model SiteContent {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  section          String
  key              String
  value            String   @default("")
  type             String   @default("text")
  sortOrder        Int      @default(0)
  isPublished      Boolean  @default(false)
  publishedContent String   @default("")
  draftContent     String   @default("")
  publishedAt      DateTime?
  locale           String   @default("fr")

  @@unique([section, key, locale])
}

enum BlogPostType {
  BLOG
  ADVICE
}

model BlogPost {
  id            String        @id @default(cuid())
  type          BlogPostType  @default(BLOG)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  title         String
  slug          String        @unique
  content       String
  excerpt       String        @default("")
  imageUrl      String?
  author        String        @default("JC Import Express")
  published     Boolean       @default(false)
  publishedAt   DateTime?
  locale        String        @default("fr")
  tags          String        @default("")
  metaTitle     String        @default("")
  metaDesc      String        @default("")
}

model Product {
  id               String               @id @default(cuid())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  slug             String               @unique
  name             String
  shortDescription String               @default("")
  fullDescription  String               @default("")
  imageUrl         String               @default("")
  gallery          String[]             @default([])
  priceXaf         Int                  @default(0)
  likes            Int                  @default(0)
  features         String[]             @default([])
  isPublished      Boolean              @default(false)
  sortOrder        Int                  @default(0)
  publishedAt      DateTime?
  testimonials     ProductTestimonial[]

  @@index([isPublished, sortOrder])
  @@index([publishedAt])
}

model ProductTestimonial {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  advice        String
  star          Int       @default(5)
  showOnLanding Boolean   @default(false)
  isPublished   Boolean   @default(true)
  sortOrder     Int       @default(0)

  @@index([productId, isPublished, sortOrder])
  @@index([showOnLanding, isPublished, sortOrder])
}

model AdminAccessKey {
  id         String    @id @default(cuid())
  key        String    @unique
  name       String?
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

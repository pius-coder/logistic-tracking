# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors & local tooling
.vscode/
.kiro/

# agent sessions & audit snapshots (local only)
session-ses_*.md
TEMP-AUDIT.md

# user uploads (filesystem storage driver)
/storage/

# unrelated build artifacts
/tmp_docx_build/
*.deb

